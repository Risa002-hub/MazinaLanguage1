<Page x:Class="MazinaLanguage1.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MazinaLanguage1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="IDTextBox" IsReadOnly="True" Background="LightGray" Margin="5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="LastNameTextBox" FontSize="14" Margin="5" MaxLength="50"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Имя:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="FirstNameTextBox" FontSize="14" Margin="5" MaxLength="50"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Отчество:" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="PatronymicTextBox" FontSize="14" Margin="5" MaxLength="50"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Email:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="EmailTextBox" FontSize="14" Margin="5"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Телефон:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="PhoneTextBox" FontSize="14" Margin="5"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата рождения:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <DatePicker Grid.Row="6" Grid.Column="1" x:Name="BirthdayDatePicker" FontSize="14" Margin="5"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Пол:*" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Margin="5">
                <RadioButton x:Name="MaleRadioButton" Content="Мужской" GroupName="Gender" Margin="0,0,20,0"/>
                <RadioButton x:Name="FemaleRadioButton" Content="Женский" GroupName="Gender"/>
            </StackPanel>

            <TextBlock Grid.Row="8" Grid.Column="2" Text="Фотография:" FontSize="14" VerticalAlignment="Center" Margin="5"/>
            <StackPanel Grid.RowSpan="7" Grid.Column="2" Orientation="Horizontal" Margin="5">
                <Image x:Name="PhotoImage" Width="100" Height="100" Stretch="UniformToFill" Margin="0,0,10,0"/>
                <Button x:Name="ChangePhotoButton" Content="Выбрать фото"  Height="30" Click="ChangePhotoButton_Click" VerticalAlignment="Top"/>
            </StackPanel>

            <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button x:Name="SaveButton" Content="Сохранить"  Height="35" Margin="5" Click="SaveButton_Click"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
